":""}, {&"car_id":"CAR-T-038-C-001-2",&"drivers":["Alfie B Davies"],&"mech":"Jack B Harris",&"pit":""}, {&"car_id":"CAR-T-038-C-001-3",&"drivers":["Alfie B Walker"],&"mech":"Finn A Taylor",&"pit":""}, {&"car_id":"CAR-T-038-C-001-4",&"drivers":["Jack A Johnson"],&"mech":"George A Brown",&"pit":""}, {&"car_id":"CAR-T-038-C-001-5",&"drivers":["James A Evans"],&"mech":"George C Evans",&"pit":""}]}, {&"name":"Yangtze Motorsport",&"tp":["Tao B Wang"],&"cfo":"Jian C Liu",&"designers":["Yang B Wang", "Ming C Li", "Tao B Li", "Hao C Yang", "Yang D Zhao", "Lei B Liu", "Wei C Li", "Tao B Zhao", "Fang A Li", "Xin C Zhao", "Tao B Zhang", "Wei B Huang", "Wei A Zhang", "Ming B Liu", "Xin A Huang", "Lei A Yang", "Tao A Zhou", "Hao B Zhou", "Hao A Huang", "Jian B Huang", "Lei C Zhang", "Fang C Chen", "Fang A Zhou"],&"strat":"",&"cars":[{&"car_id":"CAR-T-101-C-001-0",&"drivers":["Jian C Huang"],&"mech":"Fang B Li",&"pit":""}, {&"car_id":"CAR-T-101-C-001-1",&"drivers":["Lei C Zhao"],&"mech":"Tao B Huang",&"pit":""}, {&"car_id":"CAR-T-101-C-001-2",&"drivers":["Yang B Zhou"],&"mech":"Fang C Li",&"pit":""}, {&"car_id":"CAR-T-101-C-001-3",&"drivers":["Tao C Huang"],&"mech":"Fang B Zhao",&"pit":""}, {&"car_id":"CAR-T-101-C-001-4",&"drivers":["Hao C Zhang"],&"mech":"Lei B Li",&"pit":""}]}],
